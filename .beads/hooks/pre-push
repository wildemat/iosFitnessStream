#!/usr/bin/env sh
# bd-shim v1
# bd-hooks-version: 0.54.0
#
# bd (beads) pre-push hook - thin shim
#
# This shim delegates to 'bd hooks run pre-push' which contains
# the actual hook logic. This pattern ensures hook behavior is always
# in sync with the installed bd version - no manual updates needed.

# Check if bd is available
if ! command -v bd >/dev/null 2>&1; then
    echo "Warning: bd command not found in PATH, skipping pre-push hook" >&2
    echo "  Install bd: brew install beads" >&2
    echo "  Or add bd to your PATH" >&2
else
    bd hooks run pre-push "$@"
fi

# --- Version bump (minor) ---

PLIST="FitnessStream/Info.plist"
PBXPROJ="FitnessStream.xcodeproj/project.pbxproj"

# If the most recent commit is already a version bump, let the push through.
LAST_MSG=$(git log -1 --format=%s)
case "$LAST_MSG" in
    "Bump version"*) exit 0 ;;
esac

# Only bump when pushed commits touch FitnessStream* directories.
# pre-push receives "<local_ref> <local_sha> <remote_ref> <remote_sha>" on stdin.
TOUCHES_APP=false
while read local_ref local_oid remote_ref remote_oid; do
    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$local_oid"
    else
        RANGE="${remote_oid}..${local_oid}"
    fi
    if git diff --name-only "$RANGE" -- 'FitnessStream*' | grep -q .; then
        TOUCHES_APP=true
        break
    fi
done
if [ "$TOUCHES_APP" = false ]; then
    exit 0
fi

CURRENT=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "$PLIST")
MAJOR="${CURRENT%%.*}"
MINOR="${CURRENT#*.}"
NEW_MINOR=$((MINOR + 1))
NEW="${MAJOR}.${NEW_MINOR}"

/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString $NEW" "$PLIST"
sed -i '' "s/MARKETING_VERSION = ${CURRENT};/MARKETING_VERSION = ${NEW};/g" "$PBXPROJ"

git add "$PLIST" "$PBXPROJ"
git commit -m "Bump version to $NEW"

echo ""
echo "==> Version bumped to $NEW. Run 'git push' again to include the bump."
exit 1
